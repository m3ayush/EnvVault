{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "description": "HTTP requests per second by method and route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "pointSize": 5
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(envvault_http_requests_total[1m])",
          "legendFormat": "{{method}} {{route}} [{{status_code}}]",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Active Requests",
      "description": "Number of currently in-flight requests",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "expr": "envvault_active_requests",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Anomalies Detected",
      "description": "Total ML anomalies detected, by action type and user role",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(envvault_anomalies_detected_total)",
          "legendFormat": "Total Anomalies",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Latency (p95)",
      "description": "95th percentile HTTP request duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme"
          },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(envvault_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(envvault_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 latency",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Error Rate",
      "description": "HTTP 4xx and 5xx error rate per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "rate(envvault_http_requests_total{status_code=~\"4..|5..\"}[1m])",
          "legendFormat": "{{status_code}} {{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Anomaly Rate Over Time",
      "description": "Rate of anomalies detected by the ML service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "rate(envvault_anomalies_detected_total[5m])",
          "legendFormat": "{{action}} ({{user_role}})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by HTTP Method",
      "description": "Distribution of requests by HTTP method",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum by (method) (envvault_http_requests_total)",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Memory Usage (Node.js)",
      "description": "Node.js process heap memory usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          },
          "unit": "bytes"
        }
      },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"envvault-backend\"}",
          "legendFormat": "RSS Memory",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=\"envvault-backend\"}",
          "legendFormat": "Heap Used",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["envvault", "monitoring", "anomaly-detection"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "EnvVault Monitoring Dashboard",
  "uid": "envvault-main",
  "version": 1
}
